# =============================================================================
# 1. 数据库 / Database
# =============================================================================

# 现有 SQLite app.db 的路径。必填：是。应用会以只读方式打开，不写入业务数据。
# Path to an existing SQLite app.db. Required: yes. The app opens it read-only and does not write usage data.
APP_DB_PATH=./data/app.db


# =============================================================================
# 2. Web 访问与反代 / Web access and reverse proxy
# =============================================================================

# HTTP 服务监听端口。必填：否。默认值：8080。
# HTTP listen port for the application. Required: no. Default: 8080.
APP_PORT=8080

# 部署子路径；留空表示部署在根路径 /。如需子路径，必须以 / 开头，例如 /usage；/usage/ 会规范为 /usage。
# Subpath prefix; leave empty to serve from /. For subpath deployment, start with /, for example /usage; /usage/ is normalized to /usage.
APP_BASE_PATH=


# =============================================================================
# 3. 登录保护 / Login protection
# =============================================================================

# 是否启用登录保护。公网部署建议设为 true。必填：否。默认值：false。
# Whether to enable login protection. Recommended for public deployments. Required: no. Default: false.
AUTH_ENABLED=false

# 登录密码；仅在启用登录保护时必填。默认值：无。
# Login password; required only when login protection is enabled. Default: none.
LOGIN_PASSWORD=replace-with-your-login-password

# 登录 session 的有效时长。必填：否。默认值：168h。
# Lifetime of the login session. Required: no. Default: 168h.
AUTH_SESSION_TTL=168h


# =============================================================================
# 4. 使用教程 / Usage guide
# =============================================================================

# 使用教程 PDF 文件路径；留空则不显示顶部教程链接。相对路径会按 .env 所在目录解析。
# Path to a usage guide PDF; leave empty to hide the tutorial link. Relative paths are resolved from the .env directory.
TUTORIAL_PDF_PATH=


# =============================================================================
# 5. 可用模型 API / Available models API
# =============================================================================

# OpenAI-compatible models endpoint base URL. It may be the origin, /v1, or /v1/models.
AVAILABLE_MODELS_BASE_URL=https://api.openai.com

# API key used to fetch available models. Keep empty to show an empty model list.
AVAILABLE_MODELS_API_KEY=replace-with-your-api-key


# =============================================================================
# 6. OhMyGPT 查询框 / OhMyGPT query form
# =============================================================================

# Endpoint used by the model-info OhMyGPT API key query form.
# It is called by the backend with POST and a Bearer token, then filtered by the full API key entered on the page.
OHMYGPT_QUERY_URL=

# Bearer token for OHMYGPT_QUERY_URL. Keep empty to disable the query form backend.
OHMYGPT_QUERY_TOKEN=


# =============================================================================
# 7. 顶部余额命令 / Header balance command
# =============================================================================

# Command used to query header balances. Copy query_amount.example.py to query_amount.py and put private keys there.
# Example command: uv run query_amount.py
# The command must print JSON with "daily_refresh" and "pay_as_you_go" objects.
# Example: {"status":"ok","daily_refresh":{"status":"ok","remaining":12.34},"pay_as_you_go":{"status":"ok","remaining":56.78}}
# Leave empty to show query failure. Displayed amounts are rounded to two decimals.
DAILY_QUOTA_QUERY_COMMAND=

# Cache duration for the header balance command. Invalid, empty, zero, or negative values default to 10m.
DAILY_QUOTA_CACHE_TTL=10m
